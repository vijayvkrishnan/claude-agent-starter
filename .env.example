# Required: your Anthropic API key
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: per-request cost ceiling in USD. Default is $0.50.
# The agent's pre-flight hook estimates token cost from the conversation +
# tool schemas and refuses to send any request projected to exceed this.
AGENT_COST_CEILING_USD=0.50

# Optional: max iterations for the tool-use loop. Default is 12.
# Hard cap to prevent runaway loops in production.
AGENT_MAX_ITERATIONS=12
